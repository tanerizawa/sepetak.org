APP_URL=http://127.0.0.1:8000

# Beranda: angka anggota. Default tanpa env = placeholder 7862 (bukan COUNT database).
# Set true setelah data anggota aktif lengkap di database.
# HOMEPAGE_USE_REAL_MEMBER_COUNT=true
# HOMEPAGE_MEMBER_COUNT_DISPLAY=7862
# Naikkan setelah mengganti berkas di public/img/logo (cache bust).
# LOGO_ASSET_VERSION=4

# WAHA — samakan WAHA_API_KEY dengan ops/waha/.env; restart container setelah rotasi kunci.
# WAHA_ENABLED=true
# WAHA_BASE_URL=http://127.0.0.1:3000
# WAHA_API_KEY=
# WAHA_SESSION=default
# WAHA_VERIFY_SSL=false

# Generator artikel otomatis (`php artisan articles:generate` + scheduler Laravel).
# Prompt ilmiah (pillar) vs harian ringkas: kelas `AcademicPromptStrategy` vs
# `MemberPracticalPromptStrategy`; pemilihan = `ContentProfile::forArticleGeneration`.
# ARTICLE_GENERATOR_ENABLED=false
# ARTICLE_AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=anthropic/claude-3.7-sonnet
# OPENROUTER_FALLBACK_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_TEMPERATURE=0.7
# OPENROUTER_MAX_TOKENS=8000
# ARTICLE_AUTHOR_USER_ID=
# ARTICLE_MAX_PER_DAY=5
# ARTICLE_TOPIC_COOLDOWN_HOURS=0
# ARTICLE_SCHEDULE_TIMEZONE=Asia/Jakarta
# ARTICLE_MEMBER_RECENT_TITLE_DAYS=14
# ARTICLE_MEMBER_RECENT_TITLE_MAX=18
# ARTICLE_MEMBER_RECENT_TITLE_CHARS=0
# ARTICLE_QUEUE_CONNECTION=
# ARTICLE_QUEUE_NAME=default
# UNSPLASH_ENABLED=true
# UNSPLASH_ACCESS_KEY=
# PEXELS_ENABLED=true
# PEXELS_API_KEY=
# ARTICLE_IMAGE_PROVIDER_ORDER=wikimedia,pexels,unsplash