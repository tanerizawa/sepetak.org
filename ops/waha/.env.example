# Salin ke .env lalu sesuaikan, ATAU jalankan ./init-waha.sh untuk generate otomatis.
# Referensi penuh: https://github.com/devlikeapro/waha/blob/core/.env.example

# --- Wajib diganti di produksi ---
WAHA_API_KEY=00000000000000000000000000000000
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=11111111111111111111111111111111
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=11111111111111111111111111111111

WAHA_DASHBOARD_ENABLED=True
WHATSAPP_SWAGGER_ENABLED=True

WHATSAPP_DEFAULT_ENGINE=WEBJS
WAHA_NAMESPACE=all

# URL publik yang dipakai WAHA (webhook, pratinjau tautan). Sesuaikan host/port jika di balik proxy.
WAHA_BASE_URL=http://localhost:3000

WAHA_LOG_FORMAT=JSON
WAHA_LOG_LEVEL=info
WAHA_PRINT_QR=False

WAHA_MEDIA_STORAGE=LOCAL
WHATSAPP_FILES_LIFETIME=0
WHATSAPP_FILES_FOLDER=/app/.media
