# ============================================================
# .env.production.example  —  SEPETAK (Serikat Pekerja Tani Karawang)
# ------------------------------------------------------------
# Template konfigurasi produksi untuk deployment di domain
# https://sepetak.org. Salin ke `/var/www/sepetak.org/shared/.env`
# lalu isi semua placeholder <...>. JANGAN commit file berisi
# secret asli ke repo.
# ============================================================

APP_NAME=SEPETAK
APP_ENV=production
APP_KEY=<generate-dengan-php-artisan-key:generate-show>
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://sepetak.org

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ---------- Logging ----------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ---------- Database (PostgreSQL 17) ----------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=sepetak
DB_USERNAME=sepetak
DB_PASSWORD=<strong-random-password>

# ---------- Session, Cache, Queue (Redis 7) ----------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=redis
CACHE_PREFIX=sepetak_cache

QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=<redis-password-atau-null>
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ---------- Filesystem ----------
FILESYSTEM_DISK=public
# Spatie Media Library menyimpan upload di disk "public"
# Pastikan `php artisan storage:link` sudah dijalankan di release aktif

# ---------- Mail (SMTP transaksional) ----------
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=<smtp.host>
MAIL_PORT=587
MAIL_USERNAME=<smtp-user>
MAIL_PASSWORD=<smtp-password>
MAIL_FROM_ADDRESS="no-reply@sepetak.org"
MAIL_FROM_NAME="${APP_NAME}"

# ---------- AWS / S3 (opsional, tidak wajib) ----------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------- Vite ----------
VITE_APP_NAME="${APP_NAME}"

# ============================================================
# Checklist pasca-isi:
#   1. php artisan key:generate --show           # lalu tempel ke APP_KEY
#   2. php artisan config:cache
#   3. php artisan route:cache
#   4. php artisan view:cache
#   5. php artisan migrate --force
#   6. php artisan db:seed --class=DatabaseSeeder --force   # sekali saja
#   7. php artisan storage:link
#   8. npm ci && npm run build
#   9. systemctl reload php8.3-fpm && systemctl reload nginx
#  10. horizon supervisor: restart worker
# ============================================================
